# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from https://my.telegram.org -> "API development tools"
TG_API_ID=12345678
TG_API_HASH="your_api_hash_here"

# Your channel: @handle or numeric id
TG_CHANNEL="@your_channel"

# Linked discussion group:
#   auto (default) = auto-resolve from channel's linked chat
#   (empty)        = disable group mirroring entirely
#   @handle or id  = use this specific group
TG_GROUP=auto

# ── Mastodon ──────────────────────────────────────────────────────────────────
# Your instance URL
MASTO_API_BASE="https://yourinstance.social"
# Create at: https://yourinstance/settings/applications (scopes: read + write)
MASTO_ACCESS_TOKEN="your_mastodon_access_token_here"

# ── App identity ──────────────────────────────────────────────────────────────
# Base name for .db, .session, and .log files.
# Spaces become underscores in filenames (e.g. "my bot" -> my_bot.db)
APP_NAME="telegram mirror"

# Directory for all app files. Defaults to working directory if not set.
# Created automatically if it does not exist.
# DB_PATH="data"

# ── Instance / format settings ────────────────────────────────────────────────
# Post length: auto = query instance, or a number (cannot exceed instance limit)
POST_LENGTH=auto

# Post format: auto = detect from instance, markdown = use markdown (falls back
# to plain if unsupported), plain = always strip formatting
MASTODON_FORMAT=auto

# Max file upload size in bytes: auto = query instance, or a number to override
MAX_FILE_SIZE=auto

# ── New post behaviour ────────────────────────────────────────────────────────
# direct   = mirror new posts to Mastodon immediately as they arrive (default)
# buffered = queue new posts and release them on POST_TIMES schedule
# queued   = put new posts at the end of the archive queue (requires ARCHIVE=replay)
NEW_POSTS=direct

# Only used when NEW_POSTS=buffered:
# POST_TIMES="10:00,18:00"
# POST_COUNT=1

# ── Archive / backlog behaviour ───────────────────────────────────────────────
# ignore = do not post historical backlog (default)
# replay = drip all existing posts from channel history on DRIP_TIMES schedule
ARCHIVE=ignore

# Only used when ARCHIVE=replay:
# DRIP_TIMES="10:00,18:00,02:00"
# DRIP_COUNT=1

# ── Reply behaviour ───────────────────────────────────────────────────────────
# How to handle Telegram self-replies (replies to your own channel posts):
#   standalone = new Mastodon post with REPLY_TOKEN + link (default)
#   thread     = Mastodon reply/comment to the original post
REPLY_MODE=standalone

# Token prepended to the link in standalone mode. Only used when REPLY_MODE=standalone.
REPLY_TOKEN="<-"

# ── Post content ──────────────────────────────────────────────────────────────
# Hashtags appended to every channel post (not group comments).
# Must be quoted because of the # characters.
POST_TAGS=""

# Telegram display names of accounts to mirror from the discussion group.
# Comma-separated, quoted for names with spaces.
# Empty = default to main channel identity only.
MIRROR_GROUP_SENDERS=""

# ── Split style ───────────────────────────────────────────────────────────────
# Marker appended to a chunk that continues in the next post. Default: ...
# SPLIT_SUFFIX="..."

# Marker prepended to continuation chunks (2nd post onwards). Default: ...
# SPLIT_PREFIX="..."

# Chunk position indicator. %n = current chunk, %N = total chunks.
# Default: (%n/%N)   Examples: "[%n/%N]"   "post %n of %N"   "%n/%N"
# SPLIT_INDICATOR="(%n/%N)"
